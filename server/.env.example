PORT=5000
DATABASE_URL=postgres://mblob:mblob@localhost:5432/mblob
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MBLOB_REGISTRY_ADDRESS=0xBe67Af35e0E46443F0c85209497a780143CE9e4B
# Must be the private key for the deployed gateway address. Never commit the real value.
GATEWAY_PRIVATE_KEY=0x
# A random 32-byte key encoded as base64. Generate with: openssl rand -base64 32
DATA_ENCRYPTION_KEY=
STORAGE_NODE_URLS=http://localhost:4001,http://localhost:4002,http://localhost:4003
STORAGE_NODE_TOKEN=replace-with-a-long-random-token
MAX_UPLOAD_BYTES=26214400

# Storage-node-only settings. Docker Compose overrides these for each node.
STORAGE_NODE_PORT=4001
STORAGE_DATA_DIR=./data
